        <li><a href="https://matplotlib.org/" target="_blank" class="text-sky-400 hover:underline">Matplotlib: Visualization with Python</a></li>
        <li><a href="https://cryptography.io/" target="_blank" class="text-sky-400 hover:underline">cryptography: Python Library for Cryptographic Operations</a></li>
        <li><a href="https://pikepdf.readthedocs.io/" target="_blank" class="text-sky-400 hover:underline">pikepdf: PDF Manipulation in Python</a></li>
      </ul>
    </section>

  </div>

  <!-- Rodapé -->
  <footer class="bg-gray-800 text-center py-8 text-gray-400 text-sm border-t border-gray-700 mt-16">
